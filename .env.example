# Plantilla de variables de entorno.
# En el servidor: copia este archivo como .env y llena todos los valores antes
# de correr docker-compose --profile prod up -d

# Base de datos
PGPASSWORD=

# Brevo API Key (panel de Brevo → Configuración → Claves API)
BREVO_API_KEY=

# JWT — string aleatorio >= 32 chars
# Generar con: openssl rand -hex 32
JWT_SECRET=

# Dominio exacto del frontend (sin barra final)
CORS_ALLOWED_ORIGINS=https://tu-frontend.com

# URL base del frontend para los enlaces en correos
FRONTEND_URL=https://tu-frontend.com
